# ============================================================
# FONUS — Backend Environment Variables Template
#
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values below
#   3. NEVER commit the .env file to GitHub!
#
# The .gitignore already excludes .env files, so you're safe
# as long as you named the file ".env" (not ".env.example").
# ============================================================


# ──────────────────────────────────────────────────────────────
# SUPABASE — Your cloud database (postgresql)
# Get these from: https://supabase.com → your project → Settings → API
# ──────────────────────────────────────────────────────────────

# The URL of your Supabase project
# Example: https://abcxyzabc.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# The anon (public) key for Supabase — safe for server-side use
# Found under: Settings → API → Project API keys → anon / public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ACTUAL_KEY_HERE

# The service_role key — ONLY needed for admin operations like
# bypassing row-level security. Keep this EXTRA secret!
# If you don't use admin operations, leave this blank.
SUPABASE_SERVICE_ROLE_KEY=


# ──────────────────────────────────────────────────────────────
# GROQ API — The AI that powers Fonus chat
# Get API keys from: https://console.groq.com/keys
# You can add up to 30 keys for rotation (handles rate limits).
# ──────────────────────────────────────────────────────────────

# Primary Groq key (required)
GROQ_API_KEY_1=gsk_YOUR_PRIMARY_GROQ_KEY_HERE

# Additional Groq keys for key rotation (optional but recommended)
# When key_1 hits rate limits, Fonus automatically switches to key_2, etc.
GROQ_API_KEY_2=gsk_YOUR_SECOND_GROQ_KEY_HERE
GROQ_API_KEY_3=gsk_YOUR_THIRD_GROQ_KEY_HERE
# ... Add up to GROQ_API_KEY_30

# Chat-specific Groq keys (optional — same format as above)
GROQ_CHAT_KEY_1=gsk_YOUR_CHAT_KEY_HERE


# ──────────────────────────────────────────────────────────────
# GEMINI API — Fallback AI when all Groq keys are exhausted
# Get from: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────

GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_KEY_HERE

# Optional: Multiple Gemini keys for rotation
GEMINI_CHAT_KEY_1=AIzaSy_YOUR_GEMINI_CHAT_KEY_1
GEMINI_CHAT_KEY_2=AIzaSy_YOUR_GEMINI_CHAT_KEY_2


# ──────────────────────────────────────────────────────────────
# JWT — JSON Web Token secret for authentication
# This is used to sign user login tokens.
# Use a long random string — at least 64 characters.
# Generate one: python -c "import secrets; print(secrets.token_hex(64))"
# ──────────────────────────────────────────────────────────────

JWT_SECRET=REPLACE_WITH_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200   # 30 days = 43200 minutes


# ──────────────────────────────────────────────────────────────
# CORS — Which frontend domains can talk to this API
# In production: put your real domain(s) here.
# Multiple domains: separate with commas, NO spaces between.
# Local dev: include http://localhost:3000
# ──────────────────────────────────────────────────────────────

# Production + local dev example:
ALLOWED_ORIGINS=https://fonus.co.in,https://www.fonus.co.in,http://localhost:3000

# Production only (when you go live):
# ALLOWED_ORIGINS=https://fonus.co.in,https://www.fonus.co.in


# ──────────────────────────────────────────────────────────────
# APP SETTINGS
# ──────────────────────────────────────────────────────────────

# Environment: "development" or "production"
# In production, set this to "production" — affects logging and debug info.
APP_ENV=development

# Daily question limit per free user
# Change this to adjust how many questions free users can ask per day.
DAILY_QUESTION_LIMIT=20

# Port the FastAPI backend runs on (default: 8000)
PORT=8000

# ──────────────────────────────────────────────────────────────
# CLOUDFLARE R2 STORAGE (for PDFs)
# Get these from: Cloudflare Dashboard → R2 → Bucket Settings
# ──────────────────────────────────────────────────────────────

# Your Cloudflare Account ID (found on the R2 overview page)
R2_ACCOUNT_ID=your_account_id_here

# S3-compatible Access Key
R2_ACCESS_KEY=your_access_key_here

# S3-compatible Secret Key
R2_SECRET_KEY=your_secret_key_here

# The name of your bucket (e.g., fonus-pdfs)
R2_BUCKET_NAME=fonus-pdfs

# The public URL of your bucket (Custom Domain or R2.dev URL)
# Example: https://pdfs.fonus.co.in  OR  https://pub-abc.r2.dev
R2_PUBLIC_URL=https://your-r2-url.r2.dev
