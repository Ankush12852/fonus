# ============================================================
# FONUS — Root .gitignore
# ============================================================

# Virtual Environments
.venv/
venv/
env/

# Node.js / Dependencies
node_modules/
.pnp
.pnp.*
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Data and Indexes (Large Files)
data/
indexes/
dgca_index_store/

# Python Cache
__pycache__/
*.pyc

# Secrets and Environment Variables
.env
.env*
.env.local
backend/.env
*.pem
*.key

# Nginx SSL (Secrets)
nginx/ssl/*.crt
nginx/ssl/*.key

# Next.js / Build
.next/
out/
build/
*.tsbuildinfo
next-env.d.ts

# Testing
coverage/

# Misc
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.DS_Store
Thumbs.db
.vscode/
.vercel
