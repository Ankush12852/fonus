# ============================================================
# FONUS — Root .gitignore
# ============================================================

# Virtual Environments
.venv/
venv/

# Node.js
node_modules/

# Data and Indexes (Large Files)
data/
indexes/
dgca_index_store/

# Python Cache
__pycache__/
*.pyc

# Secrets and Environment Variables
.env
.env.local
backend/.env
*.pem
*.key

# Nginx SSL (Secrets)
nginx/ssl/*.crt
nginx/ssl/*.key

# Other (Optional but recommended)
*.log
.DS_Store
Thumbs.db
.vscode/
.next/
